generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ==========================================
// MODELS FOR FINDMYCLASS
// ==========================================

model User {
  id        String     @id @default(uuid())
  email     String     @unique
  nama      String
  favorites Favorite[]
  bookings  Booking[]
  createdAt DateTime   @default(now()) @map("created_at")

  @@map("fmc_users")
}

model Room {
  id        String     @id @default(uuid())
  nama      String
  gedung    String
  lantai    Int
  kapasitas Int
  fasilitas String?
  fotoURL   String?    @map("foto_url")
  schedules Schedule[]
  favorites Favorite[]
  bookings  Booking[]

  @@map("fmc_rooms")
}

model Schedule {
  id         String @id @default(uuid())
  roomId     String @map("room_id")
  mataKuliah String @map("mata_kuliah")
  dosen      String
  hari       String
  jamMulai   String @map("jam_mulai")
  jamSelesai String @map("jam_selesai")

  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("fmc_schedules")
}

model Favorite {
  id     String @id @default(uuid())
  userId String @map("user_id")
  roomId String @map("room_id")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@unique([userId, roomId])
  @@map("fmc_favorites")
}

model Booking {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  roomId     String   @map("room_id")
  tanggal    String
  jamMulai   String   @map("jam_mulai")
  jamSelesai String   @map("jam_selesai")
  keperluan  String
  status     String   @default("Disetujui")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  room Room @relation(fields: [roomId], references: [id], onDelete: Cascade)

  @@map("fmc_bookings")
}

// ==========================================
// MODELS FOR PREVIOUS PROJECT (LAUNDRY)
// ==========================================

model Admin {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String?
  photo_url String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("admins")
}

model Customer {
  id        String   @id @default(uuid())
  name      String
  phone     String?
  address   String?
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  orders    Order[]

  @@map("customers")
}

model Service {
  id        String   @id @default(uuid())
  name      String
  price     Float
  unit      String
  createdAt DateTime @default(now()) @map("created_at")
  orders    Order[]

  @@map("services")
}

model Order {
  id            String    @id @default(uuid())
  invoice       String    @unique
  customerId    String?   @map("customer_id")
  serviceId     String?   @map("service_id")
  weight        Float
  price         Float
  total         Float
  status        String    @default("Menunggu")
  paymentStatus String    @default("Belum Lunas") @map("payment_status")
  paymentMethod String?   @map("payment_method")
  entryDate     DateTime  @default(now()) @map("entry_date")
  finishDate    DateTime? @map("finish_date")
  note          String?
  createdAt     DateTime  @default(now()) @map("created_at")

  customer      Customer? @relation(fields: [customerId], references: [id], onDelete: Cascade)
  service       Service?  @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  payments      Payment[]

  @@map("orders")
}

model Payment {
  id        String   @id @default(uuid())
  orderId   String?  @map("order_id")
  amount    Float
  method    String
  paidAt    DateTime @default(now()) @map("paid_at")
  createdAt DateTime @default(now()) @map("created_at")

  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("payments")
}
